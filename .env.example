# 环境变量配置文件

# API 配置
# Put your local OpenAI API key here.
OPENAI_API_KEY=OPENAI_API_KEY
OPENAI_MODEL=gpt-5.4-mini

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=./logs/voyagent.log

# 数据库配置（如需要）
DATABASE_URL=sqlite:///./data/voyagent.db

# 应用配置
APP_NAME=VoyageAgent
APP_VERSION=0.1.0
DEBUG=False

# 缓存配置
CACHE_ENABLED=True
CACHE_TTL=3600

# 外部服务配置
# SerpApi is used for Google Maps search queries.
SERPAPI_API_KEY=your_serpapi_api_key_here
SERPAPI_ENGINE=google_maps
TRAVEL_API_KEY=your_travel_api_key_here

# 性能配置
MAX_WORKERS=4
TIMEOUT=30
