# 环境变量配置文件

# API 配置
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=./logs/voyagent.log

# 数据库配置（如需要）
DATABASE_URL=sqlite:///./data/voyagent.db

# 应用配置
APP_NAME=VoyageAgent
APP_VERSION=0.1.0
DEBUG=False

# 缓存配置
CACHE_ENABLED=True
CACHE_TTL=3600

# 外部服务配置
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
TRAVEL_API_KEY=your_travel_api_key_here

# 性能配置
MAX_WORKERS=4
TIMEOUT=30
